@model pms.Models.ManageJobsViewModel

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Jobs - MSU Admin</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        surfaceHover: '#1c2128',
                        primary: '#2f81f7',
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d',
                        danger: '#f85149'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #8b949e; }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_AdminSidebar" />

    <!-- MAIN CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background">

        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="admin">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Welcome, Admin</h2>
            <button class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary" onclick="window.location.href='/Home/Index'">Logout</button>
        </header>

        <!-- MAIN DASHBOARD CONTENT -->
        <main id="dashboard-content" class="flex-1 overflow-y-auto p-6 lg:p-8 flex flex-col">

            <div class="max-w-[1400px] mx-auto w-full flex-1 flex flex-col">

                <!-- Page Header -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                    <h3 class="text-xl text-white font-medium">Manage Job Openings</h3>
                    <span class="text-sm text-textSecondary">Total: @Model.Jobs.TotalItems jobs</span>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="mb-4 p-4 bg-green-500/10 border border-green-500/20 rounded-lg text-green-400 flex items-center gap-3">
                        <i data-lucide="check-circle" class="w-5 h-5"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }

                <!-- Action Toolbar -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                    <!-- Search Bar -->
                    <form method="get" asp-action="ManageJobs" class="relative w-full sm:w-[450px]">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="search" class="h-4 w-4 text-textSecondary"></i>
                        </div>
                        <input type="text" name="search" value="@Context.Request.Query["search"]" placeholder="Search by role or company..."
                               class="block w-full pl-10 pr-4 py-2 bg-surface border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                    </form>

                    <!-- Add Button -->
                    <a href="@Url.Action("ManageJobs_Create", "Home")"
                       class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 whitespace-nowrap w-full sm:w-auto justify-center">
                        <i data-lucide="plus" class="w-4 h-4"></i>
                        Add New Job
                    </a>
                </div>

                <!-- Data Table -->
                <div class="bg-surface border border-border rounded-xl overflow-x-auto shadow-sm">
                    <table class="w-full text-left border-collapse min-w-[1000px]">
                        <thead>
                            <tr class="border-b border-border bg-[#1c2128]/50">
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Job Role</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Company</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Package (LPA)</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm text-center">Min CGPA</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm text-center">Batch</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Last Apply Date</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @foreach (var job in Model.Jobs)
                            {
                                <tr class="border-b border-border hover:bg-surfaceHover transition-colors group">
                                    <td class="py-3 px-4">
                                        <span class="text-textPrimary font-medium">@job.JobRole</span>
                                    </td>
                                    <td class="py-3 px-4 text-textSecondary">@job.Company?.CompanyName</td>
                                    <td class="py-3 px-4 text-textSecondary">@job.Package.ToString("F1")</td>
                                    <td class="py-3 px-4 text-textSecondary text-center">@job.MinCGPA.ToString("F2")</td>
                                    <td class="py-3 px-4 text-textSecondary text-center">@job.PassingYear</td>
                                    <td class="py-3 px-4 text-textSecondary">
                                        <span class="@(job.LastApplyDate < DateTime.Now ? "text-danger" : "text-textSecondary")">
                                            @job.LastApplyDate.ToString("dd MMM yyyy")
                                        </span>
                                    </td>
                                    <td class="py-3 px-4">
                                        <div class="flex items-center justify-end gap-3 opacity-80 group-hover:opacity-100 transition-opacity">
                                            <a asp-action="EditJob" asp-route-id="@job.JobID" class="text-[#58a6ff] hover:text-white flex items-center gap-1.5 transition-colors">
                                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit
                                            </a>
                                            <form asp-action="DeleteJob" asp-route-id="@job.JobID" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-danger hover:text-[#ff7b72] flex items-center gap-1.5 transition-colors" onclick="return confirm('Are you sure you want to delete this job opening?');">
                                                    <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Jobs.Any())
                            {
                                <tr>
                                    <td colspan="7" class="py-8 text-center text-textSecondary">
                                        No job openings found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination & Rows per page -->
                <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mt-8 mb-4">
                    
                    <!-- Rows Per Page Selector -->
                    <div class="flex items-center gap-3 text-sm text-textSecondary">
                        <span>Rows per page:</span>
                        <select onchange="window.location.href='?search=@Context.Request.Query["search"]&pageSize=' + this.value" 
                                class="bg-surface border border-border rounded-md px-2 py-1 focus:outline-none focus:border-primary transition-colors cursor-pointer">
                            <option value="5" selected="@(Model.Jobs.PageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(Model.Jobs.PageSize == 10 ? "selected" : null)">10</option>
                            <option value="20" selected="@(Model.Jobs.PageSize == 20 ? "selected" : null)">20</option>
                            <option value="50" selected="@(Model.Jobs.PageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </div>

                    <!-- Pagination Controls -->
                    <div class="flex items-center gap-2 text-sm">
                        <a href="?search=@Context.Request.Query["search"]&page=@(Model.Jobs.PageIndex - 1)&pageSize=@Model.Jobs.PageSize"
                           class="h-8 px-3 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors @(!Model.Jobs.HasPreviousPage ? "pointer-events-none opacity-50" : "")">
                            Previous
                        </a>

                        @for (int i = 1; i <= Model.Jobs.TotalPages; i++)
                        {
                            if (i == Model.Jobs.PageIndex)
                            {
                                <button class="w-8 h-8 flex items-center justify-center rounded-md bg-[#1f6feb] text-white font-medium shadow-sm transition-colors cursor-default">
                                    @i
                                </button>
                            }
                            else
                            {
                                <a href="?search=@Context.Request.Query["search"]&page=@i&pageSize=@Model.Jobs.PageSize"
                                   class="w-8 h-8 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors">
                                    @i
                                </a>
                            }
                        }

                        <a href="?search=@Context.Request.Query["search"]&page=@(Model.Jobs.PageIndex + 1)&pageSize=@Model.Jobs.PageSize"
                           class="h-8 px-3 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors @(!Model.Jobs.HasNextPage ? "pointer-events-none opacity-50" : "")">
                            Next
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>
