@model pms.Models.Company
@{
    ViewBag.Title = "Edit Company";
}

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Company - MSU Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        surfaceHover: '#1c2128',
                        primary: '#2f81f7',
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d',
                        danger: '#f85149'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }
    </style>
</head>
<body class="antialiased min-h-screen flex items-center justify-center font-sans text-sm md:text-base">
    <div class="bg-surface border border-border rounded-xl shadow-lg p-8 w-full max-w-lg mx-auto">
        <div class="flex items-center gap-3 mb-6">
            <div class="bg-surface border border-border p-1.5 rounded-lg">
                <i data-lucide="building-2" class="text-primary w-6 h-6"></i>
            </div>
            <h2 class="text-xl font-bold text-white">Edit Company</h2>
        </div>
        <form asp-action="EditCompany" method="post" enctype="multipart/form-data" class="space-y-5">
            <input type="hidden" asp-for="CompanyID" />
            <div>
                <label asp-for="CompanyID" class="block text-textSecondary mb-1 font-medium">Company ID</label>
                <input asp-for="CompanyID" readonly class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="CompanyID" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CompanyName" class="block text-textSecondary mb-1 font-medium">Company Name</label>
                <input asp-for="CompanyName" required maxlength="100" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="CompanyName" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Location" class="block text-textSecondary mb-1 font-medium">Location</label>
                <input asp-for="Location" required maxlength="100" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="Location" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="VisitDate" class="block text-textSecondary mb-1 font-medium">Visit Date</label>
                <input asp-for="VisitDate" type="datetime-local" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="VisitDate" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="ContactPerson" class="block text-textSecondary mb-1 font-medium">Contact Person</label>
                <input asp-for="ContactPerson" required maxlength="100" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="ContactPerson" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="ContactEmail" class="block text-textSecondary mb-1 font-medium">Email ID</label>
                <input asp-for="ContactEmail" type="email" required maxlength="100" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="ContactEmail" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label class="block text-textSecondary mb-1 font-medium">Company Logo</label>
                <div class="flex items-center gap-4 mb-2">
                    @if (Model.CompanyLogo != null)
                    {
                        <img src="data:image/png;base64,@Convert.ToBase64String(Model.CompanyLogo)" class="w-12 h-12 rounded border border-border object-cover" />
                    }
                    <input type="file" name="companyLogo" accept="image/*" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                </div>
            </div>
            <div>
                <label asp-for="Description" class="block text-textSecondary mb-1 font-medium">Description</label>
                <textarea asp-for="Description" required maxlength="255" rows="3" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"></textarea>
                <span asp-validation-for="Description" class="text-danger text-xs mt-1"></span>
            </div>
            <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i>
                Save Changes
            </button>
        </form>
    </div>
    <script>
        lucide.createIcons();
    </script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
