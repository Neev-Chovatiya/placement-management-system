@model pms.Models.Student

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - MSU</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        surfaceHover: '#1c2128',
                        primary: '#2f81f7',
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_StudentSidebar" />

    <!-- MAIN CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background">

        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="student">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Edit Your Profile</h2>
            <button class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium transition-colors shadow-sm" onclick="window.location.href='/Home/Index'">Logout</button>
        </header>

        <!-- MAIN CONTENT -->
        <main id="dashboard-content" class="flex-1 overflow-y-auto p-6 lg:p-8">
            <div class="max-w-2xl mx-auto">
                <div class="flex items-center gap-4 mb-8">
                    <a href="@Url.Action("StudentProfile", "Home")" class="text-textSecondary hover:text-white transition-colors">
                        <i data-lucide="arrow-left" class="w-6 h-6"></i>
                    </a>
                    <h3 class="text-xl text-white font-medium">Edit Profile Details</h3>
                </div>

                <div class="bg-surface border border-border rounded-xl p-8 shadow-sm">
                    <form asp-action="EditStudentProfile" method="post" enctype="multipart/form-data" class="space-y-6">
                        <input type="hidden" asp-for="StudentID" />
                        <input type="hidden" asp-for="UserID" />

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Full Name -->
                            <div class="md:col-span-2">
                                <label asp-for="FullName" class="block text-sm font-medium text-textSecondary mb-2">Full Name</label>
                                <input asp-for="FullName" required maxlength="100" class="w-full bg-background border border-border rounded-lg px-4 py-2.5 text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                                <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1"></span>
                            </div>

                            <!-- Enrollment No (Read-only) -->
                            <div>
                                <label asp-for="EnrollmentNo" class="block text-sm font-medium text-textSecondary mb-2">Enrollment No (Locked)</label>
                                <input asp-for="EnrollmentNo" readonly class="w-full bg-[#0d1117]/50 border border-border rounded-lg px-4 py-2.5 text-textSecondary cursor-not-allowed" />
                            </div>

                            <!-- Branch (Read-only) -->
                            <div>
                                <label asp-for="Branch" class="block text-sm font-medium text-textSecondary mb-2">Branch (Locked)</label>
                                <input asp-for="Branch" readonly class="w-full bg-[#0d1117]/50 border border-border rounded-lg px-4 py-2.5 text-textSecondary cursor-not-allowed" />
                            </div>

                            <!-- Phone -->
                            <div>
                                <label asp-for="Phone" class="block text-sm font-medium text-textSecondary mb-2">Phone Number</label>
                                <input asp-for="Phone" pattern="\d{10}" title="Please enter a 10-digit phone number" class="w-full bg-background border border-border rounded-lg px-4 py-2.5 text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                                <span asp-validation-for="Phone" class="text-xs text-red-500 mt-1"></span>
                            </div>

                            <!-- Passing Year -->
                            <div>
                                <label asp-for="PassingYear" class="block text-sm font-medium text-textSecondary mb-2">Passing Year</label>
                                <input asp-for="PassingYear" type="number" min="2020" max="2035" required class="w-full bg-background border border-border rounded-lg px-4 py-2.5 text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                                <span asp-validation-for="PassingYear" class="text-xs text-red-500 mt-1"></span>
                            </div>

                            <!-- CGPA (Read-only) -->
                            <div>
                                <label asp-for="CGPA" class="block text-sm font-medium text-textSecondary mb-2">CGPA (Locked)</label>
                                <input asp-for="CGPA" readonly class="w-full bg-[#0d1117]/50 border border-border rounded-lg px-4 py-2.5 text-textSecondary cursor-not-allowed" />
                            </div>

                            <!-- Profile Picture -->
                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-textSecondary mb-2">Profile Picture</label>
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 rounded-full bg-[#0d1117] border border-border flex items-center justify-center overflow-hidden">
                                        @if (Model.ProfilePicture != null)
                                        {
                                            <img src="data:image/png;base64,@Convert.ToBase64String(Model.ProfilePicture)" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <i data-lucide="user" class="w-8 h-8 text-textSecondary"></i>
                                        }
                                    </div>
                                    <input type="file" name="profilePicture" accept="image/*" class="text-sm text-textSecondary file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-surfaceHover file:text-primary hover:file:bg-border transition-all cursor-pointer" />
                                </div>
                            </div>

                            <!-- Resume URL -->
                            <div class="md:col-span-2">
                                <label asp-for="ResumeURL" class="block text-sm font-medium text-textSecondary mb-2">Resume URL</label>
                                <input asp-for="ResumeURL" type="url" class="w-full bg-background border border-border rounded-lg px-4 py-2.5 text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="https://..." />
                                <span asp-validation-for="ResumeURL" class="text-xs text-red-500 mt-1"></span>
                            </div>
                        </div>

                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="flex-1 bg-primary hover:bg-primaryHover text-white py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2">
                                <i data-lucide="save" class="w-4 h-4"></i>
                                Save Profile Changes
                            </button>
                            <a href="@Url.Action("StudentProfile", "Home")" class="px-6 py-2.5 bg-[#21262d] hover:bg-[#30363d] border border-border text-textPrimary hover:text-white rounded-lg text-sm font-medium transition-colors">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
