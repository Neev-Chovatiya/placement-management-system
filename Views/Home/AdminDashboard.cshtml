<!--
    NOTE FOR ASP.NET RAZOR PAGES IMPLEMENTATION:

    1. _Layout.cshtml (Admin Layout):
       - Since the sidebar for the Admin portal has different links than the Student portal, you should ideally create a separate layout file for admin pages (e.g., _AdminLayout.cshtml).
       - Ensure the "Manage Students" link is set to active dynamically.

    2. AdminDashboard.cshtml:
       - The content inside the <main id="dashboard-content"> tag belongs in this view.
       - The statistics (Total Students, Companies, Jobs, Placed) should be dynamically populated from your backend logic.
         Example: Model.DashboardStats.TotalStudents
-->
@model pms.Models.DashboardStatsViewModel
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - MSU</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117', // Main app background
                        surface: '#161b22',    // Sidebar and Cards
                        surfaceHover: '#1c2128', // Hover state for lists
                        primary: '#2f81f7',    // Blue accents
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0d1117;
        }

        ::-webkit-scrollbar-thumb {
            background: #30363d;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #8b949e;
            }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_AdminSidebar" />

    <!-- MAIN CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background">

        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <!-- Mobile Menu Button -->
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="admin">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>

            <!-- Welcome Text -->
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Welcome, Admin</h2>

            <!-- Logout Button -->
            <button class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background" onclick="window.location.href='/Users/Logout'">Logout</button>
        </header>

        <!-- MAIN DASHBOARD CONTENT -->
        <main id="dashboard-content" class="flex-1 overflow-y-auto p-6 lg:p-8 flex flex-col">

            <div class="max-w-6xl mx-auto w-full flex-1 flex flex-col">
                <h3 class="text-xl text-white font-medium mb-6">Admin Dashboard</h3>

                <!-- Dashboard Stats Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 flex-1 content-start">

                    <!-- Stat Card 1: Total Students -->
                    <div class="bg-[#181d24] border border-border border-b-[5px] border-b-[#2f81f7] rounded-xl p-6 lg:p-8 shadow-md flex flex-col justify-between hover:bg-[#1c2128] transition-colors">
                        <div class="flex items-center gap-4 mb-4 md:mb-6">
                            <div class="w-12 h-12 rounded-lg bg-[#1f2937] flex items-center justify-center shadow-inner">
                                <i data-lucide="user" class="text-[#58a6ff] w-6 h-6"></i>
                            </div>
                            <span class="text-lg lg:text-xl text-textPrimary font-medium tracking-wide">Total Students</span>
                        </div>
                        <div>
                            <span class="text-4xl md:text-5xl font-bold text-white tracking-tight">@Model.TotalStudents</span>
                        </div>
                    </div>

                    <!-- Stat Card 2: Total Companies -->
                    <div class="bg-[#181d24] border border-border border-b-[5px] border-b-[#2f81f7] rounded-xl p-6 lg:p-8 shadow-md flex flex-col justify-between hover:bg-[#1c2128] transition-colors">
                        <div class="flex items-center gap-4 mb-4 md:mb-6">
                            <div class="w-12 h-12 rounded-lg bg-[#1f2937] flex items-center justify-center shadow-inner">
                                <i data-lucide="building-2" class="text-[#58a6ff] w-6 h-6"></i>
                            </div>
                            <span class="text-lg lg:text-xl text-textPrimary font-medium tracking-wide">Total Companies</span>
                        </div>
                        <div>
                            <span class="text-4xl md:text-5xl font-bold text-white tracking-tight">@Model.TotalCompanies</span>
                        </div>
                    </div>

                    <!-- Stat Card 3: Total Jobs -->
                    <div class="bg-[#181d24] border border-border border-b-[5px] border-b-[#2f81f7] rounded-xl p-6 lg:p-8 shadow-md flex flex-col justify-between hover:bg-[#1c2128] transition-colors">
                        <div class="flex items-center gap-4 mb-4 md:mb-6">
                            <div class="w-12 h-12 rounded-lg bg-[#1f2937] flex items-center justify-center shadow-inner">
                                <i data-lucide="briefcase" class="text-[#58a6ff] w-6 h-6"></i>
                            </div>
                            <span class="text-lg lg:text-xl text-textPrimary font-medium tracking-wide">Total Jobs</span>
                        </div>
                        <div>
                            <span class="text-4xl md:text-5xl font-bold text-white tracking-tight">@Model.TotalJobs</span>
                        </div>
                    </div>

                    <!-- Stat Card 4: Total Placed Students -->
                    <div class="bg-[#181d24] border border-border border-b-[5px] border-b-[#2f81f7] rounded-xl p-6 lg:p-8 shadow-md flex flex-col justify-between hover:bg-[#1c2128] transition-colors">
                        <div class="flex items-center gap-4 mb-4 md:mb-6">
                            <div class="w-12 h-12 rounded-lg bg-[#1f2937] flex items-center justify-center shadow-inner">
                                <i data-lucide="handshake" class="text-[#58a6ff] w-6 h-6"></i>
                            </div>
                            <span class="text-lg lg:text-xl text-textPrimary font-medium tracking-wide">Total Placed Students</span>
                        </div>
                        <div>
                            <span class="text-4xl md:text-5xl font-bold text-white tracking-tight">@Model.TotalPlacedStudents</span>
                        </div>
                    </div>

                </div>

              
            </div>
        </main>
    </div>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>

