@model pms.Models.Job
<!--
    NOTE FOR ASP.NET RAZOR PAGES IMPLEMENTATION:

    1. _AdminLayout.cshtml:
       - Update your sidebar navigation logic to set the "Manage Jobs" link as the active item.

    2. ManageJobs_Create.cshtml:
       - The content inside the <main id="dashboard-content"> tag belongs in this view.
       - Wrap the form elements in a <form method="post">.
       - Use ASP.NET Tag Helpers for bindings:
         <input asp-for="JobRole" ... />
         <select asp-for="CompanyID" asp-items="ViewBag.Companies" ...></select>
       - For the "Eligible Branches" checkbox list, you can use a loop over a dictionary or list of available branches in your model.
-->
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Job - MSU Admin</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117', // Main app background
                        surface: '#161b22',    // Sidebar and Cards
                        surfaceHover: '#1c2128', // Hover state for lists
                        inputBg: '#010409',    // Darker background for form inputs
                        primary: '#2f81f7',    // Blue accents
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0d1117;
        }

        ::-webkit-scrollbar-thumb {
            background: #30363d;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #8b949e;
            }

        /* Custom checkbox styling for dark theme */
        input[type="checkbox"] {
            appearance: none;
            background-color: #0d1117;
            margin: 0;
            font: inherit;
            color: currentColor;
            width: 1.15em;
            height: 1.15em;
            border: 1px solid #30363d;
            border-radius: 0.25em;
            display: grid;
            place-content: center;
            cursor: pointer;
        }

            input[type="checkbox"]::before {
                content: "";
                width: 0.65em;
                height: 0.65em;
                transform: scale(0);
                transition: 120ms transform ease-in-out;
                box-shadow: inset 1em 1em #2f81f7;
                transform-origin: center;
                clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
            }

            input[type="checkbox"]:checked::before {
                transform: scale(1);
            }

        /* Specific styles for the standard <select> elements in dark mode */
        select option {
            background-color: #161b22;
            color: #c9d1d9;
        }

            select option:checked {
                background-color: #2f81f7 !important;
                color: white !important;
            }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_AdminSidebar" />

    <!-- MAIN CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background">

        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <!-- Mobile Menu Button -->
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="admin">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>

            <!-- Welcome Text -->
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Welcome, Admin</h2>

            <!-- Logout Button -->
            <button class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background" onclick="window.location.href='/Home/Index'">Logout</button>
        </header>

        <!-- MAIN DASHBOARD CONTENT -->
        <main id="dashboard-content" class="flex-1 overflow-y-auto p-6 lg:p-8 flex flex-col">

            <div class="max-w-5xl mx-auto w-full flex-1 flex flex-col">

                <!-- Page Title -->
                <h3 class="text-xl text-white font-medium mb-6">Manage Jobs: Create a New Job Opening.</h3>

                @if (TempData["Success"] != null)
                {
                    <div class="bg-green-500/10 border border-green-500/50 text-green-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-3">
                        <i data-lucide="check-circle" class="w-5 h-5"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-500/10 border border-red-500/50 text-red-500 px-4 py-3 rounded-lg mb-6">
                        <div asp-validation-summary="All" class="text-sm"></div>
                    </div>
                }

                <!-- Form Card -->
                <div class="bg-[#181d24] border border-border rounded-xl p-6 lg:p-8 shadow-sm flex-1 flex flex-col">

                    <form asp-action="ManageJobs_Create" method="POST" class="flex flex-col h-full">

                        <!-- Section 1: New Job Entry -->
                        <div class="mb-8">
                            <h4 class="text-lg text-white font-medium">New Job Entry</h4>
                            <p class="text-sm text-textSecondary mb-6">Enter company's and instructions for new job opening.</p>

                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                                <!-- Select Company -->
                                <div>
                                    <label asp-for="CompanyID" class="block text-sm font-medium text-textPrimary mb-2">Select Company</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i data-lucide="building-2" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                        <select asp-for="CompanyID" asp-items="@ViewBag.Companies" class="appearance-none block w-full pl-10 pr-10 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-colors cursor-pointer" required>
                                            <option value="">Company: Select</option>
                                        </select>
                                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                            <i data-lucide="chevron-down" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                    </div>
                                    <span asp-validation-for="CompanyID" class="text-red-500 text-xs mt-1"></span>
                                </div>

                                <!-- Enter Role -->
                                <div>
                                    <label asp-for="JobRole" class="block text-sm font-medium text-textPrimary mb-2">Enter Role</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i data-lucide="briefcase" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                        <input asp-for="JobRole" type="text" placeholder="e.g. Software Engineer" required
                                               class="block w-full pl-10 pr-4 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                                    </div>
                                    <span asp-validation-for="JobRole" class="text-red-500 text-xs mt-1"></span>
                                </div>

                            </div>
                        </div>

                        <!-- Section 2: Job Details & Eligibility -->
                        <div class="mb-8 flex-1">
                            <h4 class="text-lg text-white font-medium mb-6">Job Details & Eligibility Section</h4>

                            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">

                                <!-- Eligible Branches (Multi-select Box) -->
                                <div class="md:col-span-3">
                                    <label class="block text-sm font-medium text-textPrimary mb-2">Eligible Branches:</label>
                                    <div class="bg-inputBg border border-border rounded-lg h-32 overflow-y-auto p-2 scrollbar-thin">
                                        @{
                                            // List of branches synchronized with the student recruitment database.
                                            // Using full branch names for consistency across all views.
                                            var branches = new[] { 
                                                "Computer Engineering", "Information Technology", "Electronics & Communication", 
                                                "Mechanical Engineering", "Civil Engineering", "Electrical Engineering", 
                                                "Chemical Engineering", "MCA", "MBA" 
                                            };
                                        }
                                        @foreach (var branch in branches)
                                        {
                                            @* Generate checkboxes for each branch to define job eligibility *@
                                            <label class="flex items-center gap-3 p-1.5 hover:bg-surfaceHover rounded cursor-pointer">
                                                <input type="checkbox" name="EligibleBranchesArray" value="@branch" class="rounded border-border text-primary focus:ring-primary bg-background">
                                                <span class="text-sm text-textPrimary">@branch</span>
                                            </label>
                                        }
                                    </div>
                                </div>

                                <!-- Year of Passing -->
                                <div class="md:col-span-3">
                                    <label asp-for="PassingYear" class="block text-sm font-medium text-textPrimary mb-2">Year of Passing:</label>
                                    <div class="relative">
                                        <select asp-for="PassingYear" class="appearance-none block w-full pl-3 pr-10 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-colors cursor-pointer" required>
                                            <option value="">Select Year</option>
                                            <option value="2026">2026</option>
                                            <option value="2025">2025</option>
                                            <option value="2024">2024</option>
                                            <option value="2023">2023</option>
                                        </select>
                                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                            <i data-lucide="chevron-down" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                    </div>
                                    <span asp-validation-for="PassingYear" class="text-red-500 text-xs mt-1"></span>
                                </div>

                                <!-- Min CGPA -->
                                <div class="md:col-span-2">
                                    <label asp-for="MinCGPA" class="block text-sm font-medium text-textPrimary mb-2">Min CGPA:</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i data-lucide="lock" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                        <input asp-for="MinCGPA" type="number" step="0.01" min="0" max="10" required placeholder="0.0 - 10.0"
                                               class="block w-full pl-10 pr-4 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                                    </div>
                                    <span asp-validation-for="MinCGPA" class="text-red-500 text-xs mt-1"></span>
                                </div>

                                <!-- Package -->
                                <div class="md:col-span-2">
                                    <label asp-for="Package" class="block text-sm font-medium text-textPrimary mb-2">Package (LPA):</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i data-lucide="indian-rupee" class="h-4 w-4 text-textSecondary"></i>
                                        </div>
                                        <input asp-for="Package" type="number" step="0.1" min="0" max="500" required placeholder="e.g. 12.5"
                                               class="block w-full pl-10 pr-4 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                                    </div>
                                    <span asp-validation-for="Package" class="text-red-500 text-xs mt-1"></span>
                                </div>

                                <!-- Last Apply Date -->
                                <div class="md:col-span-2">
                                    <label asp-for="LastApplyDate" class="block text-sm font-medium text-textPrimary mb-2">Apply By:</label>
                                    <div class="relative">
                                        <input asp-for="LastApplyDate" type="date" required
                                               class="block w-full px-4 py-2.5 bg-inputBg border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                                    </div>
                                    <span asp-validation-for="LastApplyDate" class="text-red-500 text-xs mt-1"></span>
                                </div>

                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-auto pt-6 border-t border-border/50 flex items-center justify-center gap-4">
                            <button type="submit" class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-[#181d24]">
                                <i data-lucide="save" class="w-4 h-4"></i>
                                Save Job
                            </button>
                            <a href="@Url.Action("ManageJobs", "Home")" class="bg-transparent hover:bg-surfaceHover border border-transparent hover:border-border text-textPrimary px-6 py-2.5 rounded-lg text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-textSecondary focus:ring-offset-2 focus:ring-offset-[#181d24]">
                                Cancel
                            </a>
                        </div>

                    </form>
                </div>

                <!-- Footer text -->
                <div class="text-center pb-2 mt-4">
                    <span class="text-sm text-textSecondary opacity-80">
                        MSU Jobs Management Center
                    </span>
                </div>

            </div>
        </main>
    </div>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>

