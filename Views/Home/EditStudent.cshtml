@model pms.Models.Student
@{
    ViewBag.Title = "Edit Student";
}

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student - MSU Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        surfaceHover: '#1c2128',
                        primary: '#2f81f7',
                        primaryHover: '#388bfd',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d',
                        danger: '#f85149'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }
    </style>
</head>
<body class="antialiased min-h-screen flex items-center justify-center font-sans text-sm md:text-base">
    <div class="bg-surface border border-border rounded-xl shadow-lg p-8 w-full max-w-lg mx-auto">
        <div class="flex items-center gap-3 mb-6">
            <div class="bg-surface border border-border p-1.5 rounded-lg">
                <i data-lucide="user" class="text-primary w-6 h-6"></i>
            </div>
            <h2 class="text-xl font-bold text-white">Edit Student</h2>
        </div>
        <form asp-action="EditStudent" method="post" class="space-y-5">
            <input type="hidden" asp-for="StudentID" />
            <div>
                <label asp-for="EnrollmentNo" class="block text-textSecondary mb-1 font-medium">Enrollment No</label>
                <input asp-for="EnrollmentNo" required maxlength="20" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="EnrollmentNo" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="FullName" class="block text-textSecondary mb-1 font-medium">Full Name</label>
                <input asp-for="FullName" required maxlength="100" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="FullName" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Branch" class="block text-textSecondary mb-1 font-medium">Branch</label>
                <div class="relative">
                    <select asp-for="Branch" required class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary appearance-none focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors cursor-pointer">
                        <option value="">Select Branch</option>
                        <option value="Computer Engineering">Computer Engineering</option>
                        <option value="Information Technology">Information Technology</option>
                        <option value="Electronics & Communication">Electronics & Communication</option>
                        <option value="Mechanical Engineering">Mechanical Engineering</option>
                        <option value="Civil Engineering">Civil Engineering</option>
                        <option value="Electrical Engineering">Electrical Engineering</option>
                        <option value="Chemical Engineering">Chemical Engineering</option>
                        <option value="MCA">MCA</option>
                        <option value="MBA">MBA</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <i data-lucide="chevron-down" class="w-4 h-4 text-textSecondary"></i>
                    </div>
                </div>
                <span asp-validation-for="Branch" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="PassingYear" class="block text-textSecondary mb-1 font-medium">Passing Year</label>
                <input asp-for="PassingYear" type="number" min="2020" max="2035" required class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="PassingYear" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="CGPA" class="block text-textSecondary mb-1 font-medium">CGPA</label>
                <input asp-for="CGPA" type="number" step="0.01" min="0" max="10" required class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="CGPA" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Phone" class="block text-textSecondary mb-1 font-medium">Phone</label>
                <input asp-for="Phone" required pattern="\d{10}" title="Please enter a 10-digit phone number" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="Phone" class="text-danger text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="ResumeURL" class="block text-textSecondary mb-1 font-medium">Resume URL</label>
                <input asp-for="ResumeURL" type="url" class="w-full px-4 py-2 bg-surface border border-border rounded-lg text-textPrimary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="ResumeURL" class="text-danger text-xs mt-1"></span>
            </div>
            <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i>
                Save Changes
            </button>
        </form>
    </div>
    <script>
        lucide.createIcons();
    </script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
