@model pms.Models.ManageCompaniesViewModel

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Companies - MSU Admin</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        colors: {
        background: '#0d1117', // Main app background
        surface: '#161b22',    // Sidebar and Cards
        surfaceHover: '#1c2128', // Hover state for lists
        primary: '#2f81f7',    // Blue accents
        primaryHover: '#388bfd',
        textPrimary: '#c9d1d9',
        textSecondary: '#8b949e',
        border: '#30363d',
        danger: '#f85149',     // Red for delete
        warning: '#d29922'     // Yellow/Orange for jobs
        },
        fontFamily: {
        sans: ['Inter', 'system-ui', 'sans-serif'],
        }
        }
        }
        }
    </script>
    <style>
        body {
        background-color: #0d1117;
        color: #c9d1d9;
        }

        ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
        }

        ::-webkit-scrollbar-track {
        background: #0d1117;
        }

        ::-webkit-scrollbar-thumb {
        background: #30363d;
        border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
        background: #8b949e;
        }

        /* Custom checkbox styling for dark theme */
        input[type="checkbox"] {
        appearance: none;
        background-color: #0d1117;
        margin: 0;
        font: inherit;
        color: currentColor;
        width: 1.15em;
        height: 1.15em;
        border: 1px solid #30363d;
        border-radius: 0.25em;
        display: grid;
        place-content: center;
        cursor: pointer;
        }

        input[type="checkbox"]::before {
        content: "";
        width: 0.65em;
        height: 0.65em;
        transform: scale(0);
        transition: 120ms transform ease-in-out;
        box-shadow: inset 1em 1em #2f81f7;
        transform-origin: center;
        clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0%, 43% 62%);
        }

        input[type="checkbox"]:checked::before {
        transform: scale(1);
        }

        /* Utility for Company Logos (Fallbacks) */
        .google-g {
        background: conic-gradient(from -45deg, #ea4335 110deg, #4285f4 90deg 180deg, #34a853 180deg 270deg, #fbbc05 270deg) 73% 55%/150% 150% no-repeat;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        }

        .ms-logo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-gap: 2px;
        width: 100%;
        height: 100%;
        padding: 4px;
        }

        .ms-logo-grid div:nth-child(1) {
        background-color: #f35325;
        }

        .ms-logo-grid div:nth-child(2) {
        background-color: #81bc06;
        }

        .ms-logo-grid div:nth-child(3) {
        background-color: #05a6f0;
        }

        .ms-logo-grid div:nth-child(4) {
        background-color: #ffba08;
        }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_AdminSidebar" />

    <!-- MAIN CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col overflow-hidden bg-background">

        <!-- TOP HEADER -->
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <!-- Mobile Menu Button -->
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="admin">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>

            <!-- Welcome Text -->
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Welcome, Admin</h2>

            <!-- Logout Button -->
            <button
                class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background" onclick="window.location.href='/Home/Index'">Logout</button>
        </header>

        <!-- MAIN DASHBOARD CONTENT -->
        <main id="dashboard-content" class="flex-1 overflow-y-auto p-6 lg:p-8 flex flex-col">

            <div class="max-w-[1400px] mx-auto w-full flex-1 flex flex-col">

                <!-- Page Header & Stats -->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
                    <h3 class="text-xl text-white font-medium">Manage Companies</h3>
                    <span class="text-sm text-textSecondary">Showing @Model.Companies.Count items on this page (Total: @Model.Companies.TotalItems)</span>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="mb-4 p-4 bg-danger/10 border border-danger/20 rounded-lg text-danger">
                        @TempData["Error"]
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="mb-4 p-4 bg-green-500/10 border border-green-500/20 rounded-lg text-green-400">
                        @TempData["Success"]
                    </div>
                }

                <!-- Action Toolbar -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">

                    <!-- Search Bar -->
                    <form method="get" asp-action="ManageCompanies" class="relative w-full sm:w-[450px]">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="search" class="h-4 w-4 text-textSecondary"></i>
                        </div>
                        <input type="text" name="search" value="@Context.Request.Query["search"]" placeholder="Search by company name, location, contact person..."
                               class="block w-full pl-10 pr-4 py-2 bg-surface border border-border rounded-lg text-sm text-textPrimary placeholder-textSecondary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
                    </form>

                    <!-- Add Button -->
                    <a href="@Url.Action("AddCompany", "Home")"
                        class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 whitespace-nowrap w-full sm:w-auto justify-center">
                        <i data-lucide="plus" class="w-4 h-4"></i>
                        Add New Company
                    </a>

                </div>

                <!-- Data Table -->
                <div class="bg-surface border border-border rounded-xl overflow-x-auto shadow-sm">
                    <table class="w-full text-left border-collapse min-w-[1000px]">

                        <!-- Table Head -->
                        <thead>
                            <tr class="border-b border-border bg-[#1c2128]/50">
                                <th class="py-3 px-4 w-16 text-center text-textSecondary font-medium text-sm">
                                    Logo
                                </th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Company</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Industry</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Contact Person</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Contact Email</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm">Location</th>
                                <th class="py-3 px-4 text-textSecondary font-medium text-sm text-center">Actions</th>
                            </tr>
                        </thead>

                        <!-- Table Body -->
                        <tbody class="text-sm">

                            @foreach (var company in Model.Companies)
                            {
                                <tr class="border-b border-border hover:bg-surfaceHover transition-colors group">
                                    <td class="py-3 px-4 text-center">
                                        <div class="flex justify-center">
                                            @if (company.CompanyLogo != null)
                                            {
                                                @* Display company logo from binary data using Base64 encoding *@
                                                <img src="data:image/png;base64,@Convert.ToBase64String(company.CompanyLogo)" class="w-10 h-10 rounded-lg object-contain border border-border shadow-sm" alt="Logo">
                                            }
                                            else
                                            {
                                                @* Fallback icon for companies without a logo *@
                                                <div class="w-10 h-10 rounded-lg bg-surface border border-border flex items-center justify-center text-textSecondary shadow-sm">
                                                    <i data-lucide="building-2" class="w-5 h-5"></i>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td class="py-3 px-4">
                                        <span class="text-textPrimary font-medium">@company.CompanyName</span>
                                    </td>
                                    <td class="py-3 px-4 text-textSecondary">@company.Description</td>
                                    <td class="py-3 px-4 text-textSecondary">@(string.IsNullOrEmpty(company.ContactPerson) ? "N/A" : company.ContactPerson)</td>
                                    <td class="py-3 px-4 text-textSecondary">@(string.IsNullOrEmpty(company.ContactEmail) ? "N/A" : company.ContactEmail)</td>
                                    <td class="py-3 px-4 text-textSecondary">@company.Location</td>
                                    <td class="py-3 px-4">
                                        <div class="flex items-center justify-end gap-3 opacity-80 group-hover:opacity-100 transition-opacity">
                                            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=@(company.ContactEmail)&su=@Uri.EscapeDataString("Placement Drive Inquiry - MSU")&body=@Uri.EscapeDataString($"Dear {company.ContactPerson},\n\nWe would like to discuss the upcoming campus placement drive at MSU for {company.CompanyName}. We are impressed with your organization's presence in {company.Location} and would love to facilitate a recruitment session.\n\nRegards,\nMSU Placement Office")" 
                                               target="_blank" class="text-green-400 hover:text-green-300 flex items-center gap-1.5 transition-colors" title="Email HR via Gmail">
                                                <i data-lucide="mail" class="w-3.5 h-3.5"></i> Mail
                                            </a>
                                            <a asp-action="EditCompany" asp-route-id="@company.CompanyID" class="text-[#58a6ff] hover:text-white flex items-center gap-1.5 transition-colors">
                                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit
                                            </a>
                                            <form asp-action="DeleteCompany" asp-route-id="@company.CompanyID" method="post" style="display:inline">
                                                <button type="submit" class="text-danger hover:text-[#ff7b72] flex items-center gap-1.5 transition-colors" onclick="return confirm('Are you sure you want to delete this company?');">
                                                    <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>

                <!-- Pagination & Footer text -->
                <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mt-8 mb-4">
                    
                    <!-- Rows Per Page Selector -->
                    <div class="flex items-center gap-3 text-sm text-textSecondary">
                        <span>Rows per page:</span>
                        <select onchange="window.location.href='?search=@Context.Request.Query["search"]&pageSize=' + this.value" 
                                class="bg-surface border border-border rounded-md px-2 py-1 focus:outline-none focus:border-primary transition-colors">
                            <option value="5" selected="@(Model.Companies.PageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(Model.Companies.PageSize == 10 ? "selected" : null)">10</option>
                            <option value="20" selected="@(Model.Companies.PageSize == 20 ? "selected" : null)">20</option>
                            <option value="50" selected="@(Model.Companies.PageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </div>

                    <!-- Pagination Controls -->
                    <div class="flex items-center gap-2 text-sm">
                        <a href="?search=@Context.Request.Query["search"]&page=@(Model.Companies.PageIndex - 1)&pageSize=@Model.Companies.PageSize"
                           class="h-8 px-3 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors @(!Model.Companies.HasPreviousPage ? "pointer-events-none opacity-50" : "")">
                            Previous
                        </a>

                        @for (int i = 1; i <= Model.Companies.TotalPages; i++)
                        {
                            if (i == Model.Companies.PageIndex)
                            {
                                <button class="w-8 h-8 flex items-center justify-center rounded-md bg-[#1f6feb] text-white font-medium shadow-sm transition-colors">
                                    @i
                                </button>
                            }
                            else
                            {
                                <a href="?search=@Context.Request.Query["search"]&page=@i&pageSize=@Model.Companies.PageSize"
                                   class="w-8 h-8 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors">
                                    @i
                                </a>
                            }
                        }

                        <a href="?search=@Context.Request.Query["search"]&page=@(Model.Companies.PageIndex + 1)&pageSize=@Model.Companies.PageSize"
                           class="h-8 px-3 flex items-center justify-center rounded-md text-textSecondary hover:bg-surfaceHover hover:text-white transition-colors @(!Model.Companies.HasNextPage ? "pointer-events-none opacity-50" : "")">
                            Next
                        </a>
                    </div>

                    <!-- Total Items Info -->
                    <div class="text-sm text-textSecondary">
                        Showing @((Model.Companies.PageIndex - 1) * Model.Companies.PageSize + 1) to @Math.Min(Model.Companies.PageIndex * Model.Companies.PageSize, Model.Companies.TotalItems) of @Model.Companies.TotalItems items
                    </div>

                </div>
            </div>
        </main>
    </div>
    
    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
</body>

</html>

