<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - MSU</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        primary: '#2f81f7',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background flex items-center justify-center min-h-screen p-4 font-sans antialiased text-textPrimary">
    <div class="w-full max-w-md bg-surface border border-border rounded-xl shadow-2xl overflow-hidden p-8">
        <div class="flex flex-col items-center mb-8">
            <div class="bg-[#30363d] p-3 rounded-2xl mb-4">
                <i data-lucide="shield-check" class="text-primary w-8 h-8"></i>
            </div>
            <h1 class="text-2xl font-bold text-white tracking-tight">Setup New Password</h1>
            <p class="text-sm text-textSecondary mt-2 text-center">Resetting password for: <span class="text-white">@ViewBag.Email</span></p>
        </div>

        <form asp-action="ResetPassword" method="POST" class="space-y-5">
            <input type="hidden" name="email" value="@ViewBag.Email" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-3 bg-red-500/10 border border-red-500/50 rounded-lg text-red-500 text-sm">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            @if (ViewBag.Role == "Student")
            {
                <div>
                    <label for="enrollmentNo" class="block text-sm font-medium text-textSecondary mb-2">Security Check: Enrollment Number</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="fingerprint" class="h-4 w-4 text-textSecondary"></i>
                        </div>
                        <input type="text" id="enrollmentNo" name="enrollmentNo" required placeholder="Verification Required"
                            class="block w-full pl-10 pr-4 py-2.5 bg-[#010409] border border-border rounded-lg text-sm text-textPrimary focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all">
                    </div>
                </div>
            }

            <div>
                <label for="newPassword" class="block text-sm font-medium text-textSecondary mb-2">New Password</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="lock" class="h-4 w-4 text-textSecondary"></i>
                    </div>
                    <input type="password" id="newPassword" name="newPassword" required minlength="6" placeholder="At least 6 characters"
                        class="block w-full pl-10 pr-4 py-2.5 bg-[#010409] border border-border rounded-lg text-sm text-textPrimary focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all">
                </div>
            </div>

            <div>
                <label for="confirmPassword" class="block text-sm font-medium text-textSecondary mb-2">Confirm New Password</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="lock" class="h-4 w-4 text-textSecondary"></i>
                    </div>
                    <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6" placeholder="Repeat password"
                        class="block w-full pl-10 pr-4 py-2.5 bg-[#010409] border border-border rounded-lg text-sm text-textPrimary focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all">
                </div>
            </div>

            <button type="submit" class="w-full bg-[#1f6feb] hover:bg-[#388bfd] text-white font-medium py-2.5 rounded-lg shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-surface">
                Update Password
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-border flex justify-center">
            <a href="/Home/ForgotPassword" class="text-sm text-textSecondary hover:text-white transition-colors flex items-center gap-2">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Try a different email
            </a>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>
