@model pms.Models.Placement
@{
    // ViewData["Title"] = "Placement Details";
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Placement Details - MSU Admin</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        surfaceHover: '#1c2128',
                        primary: '#2f81f7',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #8b949e; }
    </style>
</head>
<body class="antialiased h-screen flex overflow-hidden font-sans text-sm md:text-base">

    <partial name="_AdminSidebar" />

    <div class="flex-1 flex flex-col overflow-hidden bg-background">
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 border-b border-border bg-surface">
            <button class="md:hidden text-textSecondary hover:text-white" data-sidebar-toggle="admin"><i data-lucide="menu" class="w-6 h-6"></i></button>
            <h2 class="text-xl text-white font-medium ml-4 md:ml-0">Welcome, Admin</h2>
            <button class="bg-[#1f6feb] hover:bg-[#388bfd] text-white px-5 py-2 rounded-md text-sm font-medium" onclick="window.location.href='/Home/Index'">Logout</button>
        </header>

        <main class="flex-1 overflow-y-auto p-6 lg:p-8 flex flex-col">
            <div class="max-w-[1000px] mx-auto w-full flex-1 flex flex-col">
                
                <div class="flex items-center gap-4 mb-6">
                    <a href="/Home/PlacementsRegister" class="w-10 h-10 flex items-center justify-center rounded-lg bg-surface border border-border text-textSecondary hover:text-white hover:border-textSecondary transition-colors">
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    </a>
                    <div>
                        <h3 class="text-2xl text-white font-medium">Placement Record Details</h3>
                        <p class="text-textSecondary text-sm mt-1">Detailed overview of the student's placement information</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    
                    <!-- Student details -->
                    <div class="bg-surface border border-border rounded-xl p-6 shadow-sm">
                        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-border">
                            <div class="w-12 h-12 rounded-full bg-[#1f2937] border border-border flex items-center justify-center text-primary overflow-hidden">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Student?.FullName ?? "Unknown")&background=1f2937&color=58a6ff&size=64" class="w-full h-full object-cover" />
                            </div>
                            <div>
                                <h4 class="text-lg text-white font-medium">@(Model.Student?.FullName ?? "N/A")</h4>
                                <p class="text-sm text-textSecondary">Student Information</p>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Branch</span>
                                <span class="text-textPrimary">@(Model.Student?.Branch ?? "N/A")</span>
                            </div>
                            <div>
                                <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Enrollment No.</span>
                                <span class="text-textPrimary">@(Model.Student?.EnrollmentNo ?? "N/A")</span>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Passing Year</span>
                                    <span class="text-textPrimary">@(Model.Student?.PassingYear.ToString() ?? "N/A")</span>
                                </div>
                                <div>
                                    <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">CGPA</span>
                                    <span class="text-textPrimary">@(Model.Student?.CGPA.ToString() ?? "N/A")</span>
                                </div>
                            </div>
                            <div>
                                <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Phone Number</span>
                                <span class="text-textPrimary">@(Model.Student?.Phone ?? "N/A")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Company and Job details -->
                    <div class="bg-surface border border-border rounded-xl p-6 shadow-sm flex flex-col">
                        <div class="flex items-center gap-4 mb-6 pb-4 border-b border-border">
                            <div class="w-12 h-12 rounded-lg bg-[#238636] border border-border flex items-center justify-center text-white">
                                <i data-lucide="building-2" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <h4 class="text-lg text-white font-medium">@(Model.Company?.CompanyName ?? "N/A")</h4>
                                <p class="text-sm text-textSecondary">Placement Information</p>
                            </div>
                        </div>
                        
                        <div class="space-y-4 flex-1">
                            <div>
                                <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Job Role</span>
                                <span class="text-textPrimary font-medium">@(Model.Job?.JobRole ?? "N/A")</span>
                            </div>
                            <div class="p-4 bg-[#1f6feb]/10 border border-[#1f6feb]/20 rounded-lg">
                                <span class="text-xs text-[#58a6ff] uppercase tracking-wider block mb-1">Offered Package</span>
                                <span class="text-2xl text-white font-bold">@Model.Package LPA</span>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Company Location</span>
                                    <span class="text-textPrimary">@(Model.Company?.Location ?? "N/A")</span>
                                </div>
                                <div>
                                    <span class="text-xs text-textSecondary uppercase tracking-wider block mb-1">Placement Date</span>
                                    <span class="text-textPrimary">@Model.PlacementDate.ToString("dd MMM yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>

