@model pms.Models.StudentSignUpViewModel
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Student Details - MSU FTE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117', surface: '#161b22', inputBg: '#010409',
                        primary: '#2f81f7', textPrimary: '#c9d1d9', textSecondary: '#8b949e', border: '#30363d'
                    },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
        select option { background-color: #161b22; color: #c9d1d9; }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col font-sans">

    <!-- Header -->
    <header class="flex flex-col md:flex-row justify-between items-center px-4 sm:px-6 lg:px-8 py-6 max-w-7xl mx-auto w-full border-b border-[#30363d]/50 md:border-none">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <div class="bg-[#161b22] border border-[#30363d] p-2 rounded-lg">
                <i data-lucide="graduation-cap" class="text-[#2f81f7] w-8 h-8"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-white leading-tight">MSU</h1>
                <p class="text-xs text-[#8b949e] uppercase tracking-wider">FTE</p>
            </div>
        </div>
        <nav class="flex gap-6 text-sm font-medium">
            <a href="/Home/Index" class="text-[#c9d1d9] hover:text-white transition-colors">Home</a>
            <a href="/Users/Login" class="text-[#c9d1d9] hover:text-white transition-colors">Login</a>
            <a href="/Users/SignUp" class="text-[#2f81f7]">Sign Up</a>
        </nav>
    </header>

    <main class="flex-grow flex items-center justify-center p-4 py-8">
        <div class="bg-[#161b22] border border-[#30363d] rounded-2xl w-full max-w-lg p-8 shadow-2xl shadow-black/50 relative overflow-hidden">

            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-24 bg-[#2f81f7]/5 blur-3xl rounded-full pointer-events-none"></div>

            <!-- Step indicator -->
            <div class="flex items-center justify-center gap-2 mb-6 relative z-10">
                <div class="flex items-center gap-1.5">
                    <div class="w-7 h-7 rounded-full bg-[#2f81f7]/30 border border-[#2f81f7]/50 text-[#2f81f7] flex items-center justify-center text-xs font-bold">✓</div>
                    <span class="text-xs text-[#8b949e]">Account Info</span>
                </div>
                <div class="w-8 h-px bg-[#2f81f7]/50"></div>
                <div class="flex items-center gap-1.5">
                    <div class="w-7 h-7 rounded-full bg-[#2f81f7] text-white flex items-center justify-center text-xs font-bold">2</div>
                    <span class="text-xs text-white font-medium">Student Details</span>
                </div>
            </div>

            <h2 class="text-2xl font-semibold text-white text-center mb-1 relative z-10">Student Details</h2>
            <p class="text-sm text-[#8b949e] text-center mb-6 relative z-10">Step 2 of 2 — Fill in your academic information</p>

            <form asp-action="SignUpStudent" asp-controller="Users" method="post" class="space-y-4 relative z-10">
                @Html.AntiForgeryToken()

                <!-- Hidden carry-over fields -->
                <input type="hidden" asp-for="Username" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Password" />

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="bg-red-900/40 border border-red-700/50 text-red-300 rounded-lg px-3 py-2 text-sm">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <!-- Full Name -->
                <div>
                    <label for="FullName" class="block text-sm text-[#8b949e] mb-1.5">Full Name <span class="text-red-400">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="user" class="h-4 w-4 text-[#8b949e]"></i>
                        </div>
                        <input asp-for="FullName" type="text" placeholder="e.g. Rahul Sharma" maxlength="100"
                               class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors" required>
                    </div>
                    <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Enrollment No -->
                <div>
                    <label for="EnrollmentNo" class="block text-sm text-[#8b949e] mb-1.5">Enrollment No <span class="text-red-400">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="hash" class="h-4 w-4 text-[#8b949e]"></i>
                        </div>
                        <input asp-for="EnrollmentNo" type="text" placeholder="e.g. 21IT001" maxlength="20"
                               class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors" required>
                    </div>
                    <span asp-validation-for="EnrollmentNo" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Branch + Passing Year (side by side) -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="Branch" class="block text-sm text-[#8b949e] mb-1.5">Branch <span class="text-red-400">*</span></label>
                        <div class="relative">
                            <select asp-for="Branch" class="appearance-none block w-full pl-3 pr-8 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors cursor-pointer" required>
                                <option value="">Select</option>
                                <option value="Computer Engineering">Computer Engineering</option>
                                <option value="Information Technology">Information Technology</option>
                                <option value="Electronics & Communication">Electronics & Communication</option>
                                <option value="Mechanical Engineering">Mechanical Engineering</option>
                                <option value="Civil Engineering">Civil Engineering</option>
                                <option value="Electrical Engineering">Electrical Engineering</option>
                                <option value="Chemical Engineering">Chemical Engineering</option>
                                <option value="MCA">MCA</option>
                                <option value="MBA">MBA</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 pr-2 flex items-center pointer-events-none">
                                <i data-lucide="chevron-down" class="h-4 w-4 text-[#8b949e]"></i>
                            </div>
                        </div>
                        <span asp-validation-for="Branch" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div>
                        <label for="PassingYear" class="block text-sm text-[#8b949e] mb-1.5">Passing Year <span class="text-red-400">*</span></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="calendar" class="h-4 w-4 text-[#8b949e]"></i>
                            </div>
                            <input asp-for="PassingYear" type="number" placeholder="e.g. 2025" min="2020" max="2035"
                                   class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors" required>
                        </div>
                        <span asp-validation-for="PassingYear" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <!-- CGPA + Phone (side by side) -->
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="CGPA" class="block text-sm text-[#8b949e] mb-1.5">CGPA <span class="text-red-400">*</span></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="bar-chart-2" class="h-4 w-4 text-[#8b949e]"></i>
                            </div>
                            <input asp-for="CGPA" type="number" step="0.01" placeholder="0.0 – 10.0" min="0" max="10"
                                   class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors" required>
                        </div>
                        <span asp-validation-for="CGPA" class="text-red-500 text-xs mt-1"></span>
                    </div>
                    <div>
                        <label for="Phone" class="block text-sm text-[#8b949e] mb-1.5">Phone</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="phone" class="h-4 w-4 text-[#8b949e]"></i>
                            </div>
                            <input asp-for="Phone" type="tel" placeholder="10-digit number" pattern="\d{10}" title="Please enter a 10-digit phone number"
                                   class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors">
                        </div>
                        <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <!-- Resume URL -->
                <div>
                    <label for="ResumeURL" class="block text-sm text-[#8b949e] mb-1.5">Resume URL <span class="text-xs text-[#8b949e]/60">(optional)</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="link" class="h-4 w-4 text-[#8b949e]"></i>
                        </div>
                        <input asp-for="ResumeURL" type="url" placeholder="https://drive.google.com/your-resume"
                               class="block w-full pl-10 pr-3 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-[#2f81f7] focus:border-[#2f81f7] transition-colors">
                    </div>
                    <span asp-validation-for="ResumeURL" class="text-red-500 text-xs mt-1"></span>
                    <p class="text-xs text-[#8b949e]/70 mt-1">Link to your Google Drive, OneDrive, or any public resume URL.</p>
                </div>

                <div class="flex gap-3 pt-2">
                    <a href="/Users/SignUp" class="flex-shrink-0 px-4 py-2.5 border border-[#30363d] text-[#8b949e] hover:text-white hover:border-[#8b949e] rounded-lg text-sm transition-colors flex items-center gap-1.5">
                        <i data-lucide="arrow-left" class="h-4 w-4"></i>
                        Back
                    </a>
                    <button type="submit"
                            class="flex-1 bg-[#1f6feb] hover:bg-[#388bfd] text-white font-medium py-2.5 rounded-lg shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-[#2f81f7] focus:ring-offset-2 focus:ring-offset-[#161b22] tracking-wide flex items-center justify-center gap-2">
                        <i data-lucide="user-check" class="h-4 w-4"></i>
                        Create Account
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>lucide.createIcons();</script>
</body>
</html>
