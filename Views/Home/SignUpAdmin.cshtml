<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Verification - MSU FTE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117', surface: '#161b22', inputBg: '#010409',
                        primary: '#2f81f7', textPrimary: '#c9d1d9', textSecondary: '#8b949e', border: '#30363d'
                    },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>body { background-color: #0d1117; color: #c9d1d9; }</style>
</head>
<body class="antialiased min-h-screen flex flex-col font-sans">

    <!-- Header -->
    <header class="flex flex-col md:flex-row justify-between items-center px-4 sm:px-6 lg:px-8 py-6 max-w-7xl mx-auto w-full border-b border-[#30363d]/50 md:border-none">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <div class="bg-[#161b22] border border-[#30363d] p-2 rounded-lg">
                <i data-lucide="graduation-cap" class="text-[#2f81f7] w-8 h-8"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-white leading-tight">MSU</h1>
                <p class="text-xs text-[#8b949e] uppercase tracking-wider">FTE</p>
            </div>
        </div>
        <nav class="flex gap-6 text-sm font-medium">
            <a href="/Home/Index" class="text-[#c9d1d9] hover:text-white transition-colors">Home</a>
            <a href="/Users/Login" class="text-[#c9d1d9] hover:text-white transition-colors">Login</a>
            <a href="/Users/SignUp" class="text-[#2f81f7]">Sign Up</a>
        </nav>
    </header>

    <main class="flex-grow flex items-center justify-center p-4">
        <div class="bg-[#161b22] border border-[#30363d] rounded-2xl w-full max-w-md p-8 shadow-2xl shadow-black/50 relative overflow-hidden">

            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-24 bg-amber-500/5 blur-3xl rounded-full pointer-events-none"></div>

            <!-- Icon Badge -->
            <div class="flex justify-center mb-4 relative z-10">
                <div class="w-14 h-14 rounded-2xl bg-amber-500/10 border border-amber-500/30 flex items-center justify-center">
                    <i data-lucide="shield-check" class="text-amber-400 w-7 h-7"></i>
                </div>
            </div>

            <h2 class="text-2xl font-semibold text-white text-center mb-2 relative z-10">Admin Verification</h2>
            <p class="text-sm text-[#8b949e] text-center mb-6 relative z-10">
                Enter the secret key provided by your existing admin to create an admin account.
            </p>

            <form asp-action="SignUpAdmin" asp-controller="Users" method="post" class="space-y-5 relative z-10">
                @Html.AntiForgeryToken()

                <!-- Hidden carry-over fields from TempData → written by controller into ViewBag or passed via query -->
                <input type="hidden" name="username" value="@TempData.Peek("SignUp_Username")" />
                <input type="hidden" name="email"    value="@TempData.Peek("SignUp_Email")" />
                <input type="hidden" name="password" value="@TempData.Peek("SignUp_Password")" />

                @{
                    // Keep TempData alive for a potential re-render on validation error
                    TempData.Keep("SignUp_Username");
                    TempData.Keep("SignUp_Email");
                    TempData.Keep("SignUp_Password");
                }

                @if (ViewBag.Error != null)
                {
                    <div class="bg-red-900/40 border border-red-700/50 text-red-300 rounded-lg px-4 py-3 text-sm flex gap-2 items-start">
                        <i data-lucide="alert-circle" class="h-4 w-4 flex-shrink-0 mt-0.5"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                <!-- Secret Key Field -->
                <div>
                    <label for="secretKey" class="block text-sm text-[#8b949e] mb-1.5">Secret Key</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="key" class="h-4 w-4 text-[#8b949e]"></i>
                        </div>
                        <input type="password" id="secretKey" name="secretKey" placeholder="Paste your secret key here"
                               class="block w-full pl-10 pr-10 py-2.5 bg-[#010409] border border-[#30363d] rounded-lg text-sm text-[#c9d1d9] placeholder-[#8b949e]/70 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 transition-colors">
                        <button type="button" onclick="togglePwd('secretKey', this)" class="absolute inset-y-0 right-0 pr-3 flex items-center text-[#8b949e] hover:text-white transition-colors">
                            <i data-lucide="eye-off" class="h-4 w-4"></i>
                        </button>
                    </div>
                    <p class="text-xs text-[#8b949e] mt-2 italic px-1">
                        <i data-lucide="info" class="w-3 h-3 inline mr-1"></i>
                        Note: If you are the first administrator, you can leave this field blank.
                    </p>
                </div>

                <div class="flex gap-3 pt-2">
                    <a href="/Users/SignUp" class="flex-shrink-0 px-4 py-2.5 border border-[#30363d] text-[#8b949e] hover:text-white hover:border-[#8b949e] rounded-lg text-sm transition-colors flex items-center gap-1.5">
                        <i data-lucide="arrow-left" class="h-4 w-4"></i>
                        Back
                    </a>
                    <button type="submit"
                            class="flex-1 bg-amber-600 hover:bg-amber-500 text-white font-medium py-2.5 rounded-lg shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2 focus:ring-offset-[#161b22] tracking-wide flex items-center justify-center gap-2">
                        <i data-lucide="shield-check" class="h-4 w-4"></i>
                        Verify & Create Account
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        lucide.createIcons();
        function togglePwd(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('i');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.setAttribute('data-lucide', input.type === 'password' ? 'eye-off' : 'eye');
            lucide.createIcons();
        }
    </script>
</body>
</html>
