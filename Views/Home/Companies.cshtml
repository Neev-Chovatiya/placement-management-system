@model IEnumerable<pms.Models.Company>
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recruiting Partners - MSU Institute</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#0d1117',
                        surface: '#161b22',
                        primary: '#2f81f7',
                        textPrimary: '#c9d1d9',
                        textSecondary: '#8b949e',
                        border: '#30363d'
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col font-sans">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 w-full flex-grow">
        <header class="flex flex-col md:flex-row justify-between items-center mb-16 gap-6 md:gap-0">
            <a href="/" class="flex items-center gap-3">
                <div class="bg-surface border border-border p-2 rounded-lg">
                    <i data-lucide="graduation-cap" class="text-primary w-8 h-8"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-white leading-tight">MSU</h1>
                    <p class="text-xs text-textSecondary uppercase tracking-wider">FTE</p>
                </div>
            </a>
            <nav class="flex gap-6 text-sm font-medium">
                <a href="/" class="text-textPrimary hover:text-white transition-colors">Home</a>
                <a asp-action="AboutPlacements" asp-controller="Home" class="text-textPrimary hover:text-white transition-colors">About Placements</a>
                <a asp-action="Companies" asp-controller="Home" class="text-primary border-b-2 border-primary pb-1">Companies</a>
                <a href="/Home/Login" class="text-textPrimary hover:text-white transition-colors">Login</a>
            </nav>
        </header>

        <main>
            <div class="mb-12">
                <h2 class="text-4xl font-bold text-white mb-4">Our Recruiting Partners</h2>
                <p class="text-lg text-textSecondary max-w-2xl">We are proud to partner with leading organizations across various industries, providing our students with a wide spectrum of career choices.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @if (Model != null && Model.Any())
                {
                    foreach (var company in Model)
                    {
                        <div class="bg-surface border border-border p-6 rounded-2xl hover:border-primary/50 transition-colors group">
                            <div class="flex items-start justify-between mb-4">
                                <div class="bg-[#1c2128] p-3 rounded-xl border border-border group-hover:bg-primary/10 group-hover:border-primary/30 transition-colors">
                                    <i data-lucide="building-2" class="text-primary w-6 h-6"></i>
                                </div>
                                <span class="bg-[#238636]/10 text-[#3fb950] text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider border border-[#238636]/20">Active Partner</span>
                            </div>
                            <h3 class="text-xl font-bold text-white mb-2">@company.CompanyName</h3>
                            <p class="text-textSecondary text-sm mb-4 line-clamp-2">@company.Description</p>
                            <div class="flex items-center gap-2 text-xs text-textSecondary">
                                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                                <span>@company.Location</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-full py-20 text-center">
                        <i data-lucide="search-x" class="text-textSecondary w-12 h-12 mx-auto mb-4 opacity-50"></i>
                        <h4 class="text-xl font-medium text-white mb-2">No companies found</h4>
                        <p class="text-textSecondary">Stay tuned as we bring more partners on board.</p>
                    </div>
                }
            </div>
        </main>

        <footer class="mt-20 py-8 border-t border-border text-center text-textSecondary text-sm">
            &copy; @DateTime.Now.Year MSU FTE. All rights reserved.
        </footer>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>
